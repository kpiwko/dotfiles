[user]
	email = kpiwko@redhat.com
    name = Karel Piwko
	signingkey = ~/.ssh/kpiwko_github_signing_ed25519
[core]
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    light = true
[merge]
    conflictStyle = zdiff3
[advice]
	skippedCherryPicks = false
[push]
	autoSetupRemote = true
[init]
	templateDir = ~/.git-templates
[include]
	path = ~/.gitconfig.local
[credential]
	helper = osxkeychain
[gpg]
	format = ssh
[commit]
	gpgsign = true
