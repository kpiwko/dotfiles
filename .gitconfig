    name = Karel Piwko
[core]
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    light = true
[merge]
    conflictStyle = zdiff3
[advice]
	skippedCherryPicks = false
[push]
	autoSetupRemote = true
[init]
	templateDir = /Users/kpiwko/.git-templates
